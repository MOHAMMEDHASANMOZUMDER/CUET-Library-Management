modules = ["java", "maven"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["jdk", "maven"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Spring Boot Server"

[[workflows.workflow]]
name = "Spring Boot Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mvn clean install -DskipTests && mvn spring-boot:run -Dspring-boot.run.args=\"--server.port=5000\""
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
